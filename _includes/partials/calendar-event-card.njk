{% set tz = event.data.timezone | default("America/New_York") %}
{% set parts = event.data.date | calendarDateParts(tz) %}
<article class="calendar-event-card">
  <header class="calendar-event-card__top">
    <div class="calendar-event-card__tags">
      {% for tag in event.data.eventTags %}
        <span class="calendar-event-card__tag {% if loop.index0 == 0 %}calendar-event-card__tag--fill{% else %}calendar-event-card__tag--outline{% endif %}">{{ tag | upper }}</span>
      {% endfor %}
    </div>
    <span class="calendar-event-card__radio" aria-hidden="true"></span>
  </header>

  <div class="calendar-event-card__main">
    <div class="calendar-event-card__date-block" aria-hidden="true">
      <span class="calendar-event-card__dow">{{ parts.weekday }}</span>
      <span class="calendar-event-card__month">{{ parts.month }}</span>
      <span class="calendar-event-card__dom">{{ parts.dayOrdinal }}</span>
    </div>
    <div class="calendar-event-card__details">
      <h3 class="calendar-event-card__title">
        <a href="{{ event.url }}">{{ event.data.title }}</a>
      </h3>
      <p class="calendar-event-card__line">{{ event.data.date | formatEventDateLong(tz) }}</p>
      <p class="calendar-event-card__line">{{ event.data.date | formatEventTimeRange(event.data.end | default(event.data.date), tz) }}</p>
      <p class="calendar-event-card__line calendar-event-card__location">@ {{ event.data.location }}</p>
    </div>
  </div>

  <p class="calendar-event-card__desc">{{ event.data.description }}</p>
  <p class="calendar-event-card__cta">
    <a href="{{ event.url }}">LEARN MORE</a>
  </p>
</article>
